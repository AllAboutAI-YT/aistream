# AIStream director — copy to .env and fill in.
# Secrets only — never commit the real .env.

# HTTP server bind. Defaults to localhost; only widen on a trusted LAN.
HOST=127.0.0.1
PORT=7878

# OBS WebSocket (default endpoint when "Enable WebSocket server" is on).
OBS_WEBSOCKET_URL=ws://127.0.0.1:4455
OBS_WEBSOCKET_PASSWORD=

# Reject /agent-decision requests with confidence below this threshold.
AGENT_MIN_CONFIDENCE=0.7

# How many recent decisions to keep in memory and expose via /status.
DECISION_LOG_SIZE=100

# Path to the scene registry, relative to cwd.
SOURCES_FILE=sources.json
